// Veto — Prisma schema (v2)
// Deterministic, verifiable policy gate for AI agents on Sui.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support native enums, so we use string with a TS-side union.

model Rule {
  id        String   @id @default(cuid())
  name      String
  type      String   // "MAX_AMOUNT_PER_TX" | "DAILY_SPEND_CAP" | "ALLOWED_RECIPIENT" | "DENYLIST_ADDRESS"
  config    String   // JSON-encoded config (sqlite has no Json type)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentRequest {
  id           String   @id @default(cuid())
  rawMessage   String
  parsedIntent String?  // JSON-encoded
  amountSui    Float?
  recipient    String?
  status       String   @default("PENDING") // PENDING | APPROVED | BLOCKED | EXECUTED | FAILED | AWAITING_CONFIRMATION
  failedRule   String?
  failReason   String?
  txDigest     String?
  // For two-step confirmation flow: when status = AWAITING_CONFIRMATION,
  // the parsed intent is staged but not yet executed. User must confirm.
  // Set to the timestamp when user confirmed (null until then).
  confirmedAt  DateTime?
  createdAt    DateTime @default(now())
}

model RuleBookCommit {
  id          String   @id @default(cuid())
  commitHash  String   // SHA-256 of canonical rule set JSON (0x-prefixed hex)
  version     Int      // monotonically increasing
  txDigest    String?  // null in simulator mode; real digest once Move is deployed
  createdAt   DateTime @default(now())
}
